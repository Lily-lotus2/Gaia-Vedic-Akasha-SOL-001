# SILO C Integration (Google Drive)
# Configure these in Vercel dashboard or local .env.local file

# Google Drive API Key for SILO C access
GOOGLE_DRIVE_API_KEY=YOUR_GOOGLE_DRIVE_API_KEY

# Google Drive Folder ID for SILO-C-EXISTON-LOG
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# SILO C Synchronization Configuration
# Sync interval in milliseconds (default: 100ms)
SILO_C_SYNC_INTERVAL_MS=100

# Existon Update Frequency
# Update frequency in Hz (default: 10 Hz)
EXISTON_UPDATE_FREQUENCY_HZ=10

# Node Environment
NODE_ENV=production

# Optional: Custom logging path (default: ./data/existon-log.jsonl)
# LOG_PATH=./data/existon-log.jsonl
